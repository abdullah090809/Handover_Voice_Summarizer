# Copy this file to .env and fill in your backend URLs.
# The FastAPI backend already implements every endpoint this app calls.

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_WS_BASE_URL=ws://127.0.0.1:8000

# Cloudflare Turnstile site key used on the Sign In form (register/verify
# don't require it — only /login does, per the backend).
# For local development you can use Cloudflare's published dummy test key
# below, which always passes — just make sure the backend's
# TURNSTILE_SECRET_KEY env var is set to Cloudflare's matching test secret
# (1x0000000000000000000000000000000AA). For production, create a real
# Turnstile widget in your Cloudflare dashboard and use that site key here,
# with its matching secret key set on the backend.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAD1jVPsPt4TsxsQi
